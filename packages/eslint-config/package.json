{
  "name": "@ddoblue/eslint-config",
  "version": "0.3.1",
  "license": "ISC",
  "author": "Raey",
  "description": "Shared ESLint configuration",
  "homepage": "https://github.com/nxnaxx/ddoblue-devkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/nxnaxx/ddoblue-devkit.git",
    "directory": "packages/eslint-config"
  },
  "keywords": [
    "ddoblue",
    "eslint",
    "eslint-config"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm run clean && pnpm tsup",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./base": {
      "import": "./dist/base.js",
      "types": "./dist/base.d.ts"
    },
    "./typescript": {
      "import": "./dist/typescript.js",
      "types": "./dist/typescript.d.ts"
    },
    "./import": {
      "import": "./dist/import.js",
      "types": "./dist/import.d.ts"
    },
    "./import/boundary": {
      "import": "./dist/import/boundary.js",
      "types": "./dist/import/boundary.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "types": "./dist/next.d.ts"
    },
    "./node": {
      "import": "./dist/node.js",
      "types": "./dist/node.d.ts"
    },
    "./prettier": {
      "import": "./dist/prettier.js",
      "types": "./dist/prettier.d.ts"
    },
    "./storybook": {
      "import": "./dist/storybook.js",
      "types": "./dist/storybook.d.ts"
    },
    "./presets/react": {
      "import": "./dist/presets/react.js",
      "types": "./dist/presets/react.d.ts"
    },
    "./presets/react-strict": {
      "import": "./dist/presets/react-strict.js",
      "types": "./dist/presets/react-strict.d.ts"
    },
    "./presets/next": {
      "import": "./dist/presets/next.js",
      "types": "./dist/presets/next.d.ts"
    },
    "./presets/next-strict": {
      "import": "./dist/presets/next-strict.js",
      "types": "./dist/presets/next-strict.d.ts"
    },
    "./presets/nest": {
      "import": "./dist/presets/nest.js",
      "types": "./dist/presets/nest.d.ts"
    },
    "./presets/library": {
      "import": "./dist/presets/library.js",
      "types": "./dist/presets/library.d.ts"
    }
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^10.3.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript-eslint": "^8.57.1"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  },
  "peerDependencies": {
    "eslint": "^9.0.0 || ^10.0.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
