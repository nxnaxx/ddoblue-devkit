{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "cache": false,
      "dependsOn": ["build"]
    },
    "test:fix": {
      "cache": false,
      "dependsOn": ["build"]
    }
  }
}
